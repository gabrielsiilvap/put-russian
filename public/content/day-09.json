        { "speaker": "B", "ru": "Я встречаю брата и сестру.", "en": "I'm meeting my brother and sister." },
        { "speaker": "A", "ru": "Здорово! Пьёте кофе вместе?", "en": "Great! Are you drinking coffee together?" },
        { "speaker": "B", "ru": "Да, конечно!", "en": "Yes, of course!" }
      ],
      "glossWords": [ { "ru": "кого", "en": "whom (accusative of кто)" } ]
    }
  ],

