        { "speaker": "B", "ru": "Ты ешь рыбу каждый день?", "en": "Do you eat fish every day?" },
        { "speaker": "A", "ru": "Нет, не каждый день. Но люблю рыбу.", "en": "No, not every day. But I love fish." }
      ],
      "glossWords": [ { "ru": "каждый день", "en": "every day" } ]
    },
    {
      "title": "Meeting family",
      "lines": [
