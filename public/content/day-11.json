  "dialogues": [
    {
      "title": "How often?",
      "lines": [
        { "speaker": "A", "ru": "Ты часто занимаешься спортом?", "en": "Do you do sports often?" },
        { "speaker": "B", "ru": "Да, каждый день! А ты?", "en": "Yes, every day! And you?" },
        { "speaker": "A", "ru": "Я редко. Иногда гуляю, но это всё.", "en": "I rarely do. Sometimes I walk, but that's all." },
        { "speaker": "B", "ru": "Понимаю, ты занятый человек.", "en": "I understand, you're a busy person." }
      ]
    },
    {
      "title": "Never on Sunday",
      "lines": [
        { "speaker": "A", "ru": "Ты работаешь каждый день?", "en": "Do you work every day?" },
        { "speaker": "B", "ru": "Нет, никогда не работаю в выходной.", "en": "No, I never work on a day off." },
        { "speaker": "A", "ru": "Что ты делаешь?", "en": "What do you do?" },
        { "speaker": "B", "ru": "Отдыхаю! Убираю дом, иногда читаю.", "en": "I rest! I clean the house, sometimes I read." }
      ],
      "glossWords": [ { "ru": "выходной", "en": "day off" } ]
    }
  ],

  "comprehension": [
    { "q": "In dialogue 1, how often does speaker A do sports?", "type": "understand", "answer": "rarely", "acceptable": ["редко", "rarely"] },
