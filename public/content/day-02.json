    { "id": "w0127", "ru": "здесь", "en": "here", "pos": "adv", "example": { "ru": "Я здесь.", "en": "I am here." } },
    { "id": "w0128", "ru": "там", "en": "there", "pos": "adv", "example": { "ru": "Вода там.", "en": "The water is there." } },
    { "id": "w0129", "ru": "дома", "en": "at home", "pos": "adv", "example": { "ru": "Я дома.", "en": "I am at home." } },
