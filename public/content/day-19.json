    { "id": "w0369", "ru": "фрукты", "en": "fruits", "pos": "noun", "gender": "pl", "example": { "ru": "Я люблю фрукты.", "en": "I love fruits." } },
    { "id": "w0370", "ru": "литр", "en": "liter", "pos": "noun", "gender": "m", "example": { "ru": "Один литр молока.", "en": "One liter of milk." } }
  ],

  "dialogues": [
    {
      "title": "How much time do you have?",
      "lines": [
        { "speaker": "A", "ru": "Сколько времени у тебя сегодня?", "en": "How much time do you have today?" },
        { "speaker": "B", "ru": "Много! А у тебя?", "en": "A lot! And you?" },
        { "speaker": "A", "ru": "Мало. Очень много работы.", "en": "Not much. So much work." },
        { "speaker": "B", "ru": "Жаль! Может быть, завтра.", "en": "What a shame! Maybe tomorrow." }
      ]
    },
    {
      "title": "Cooking",
      "lines": [
        { "speaker": "A", "ru": "У нас есть рис и картошка. А лук?", "en": "We have rice and potatoes. And onion?" },
        { "speaker": "B", "ru": "Мало лука, но достаточно соли.", "en": "Not much onion, but enough salt." },
        { "speaker": "A", "ru": "Хорошо. А сколько молока?", "en": "Good. And how much milk?" },
        { "speaker": "B", "ru": "Один литр. Достаточно!", "en": "One liter. Enough!" }
      ]
    }
  ],

