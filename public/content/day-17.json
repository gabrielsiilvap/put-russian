  "grammarPoint": {
    "title": "У меня нет...: the genitive shows up for real",
    "explanation": "**Нет** (there isn't) + a noun in the **genitive** is how you say you don't have something: **У меня́ нет вре́мени** — I don't have time. Unlike «есть» sentences (object stays nominative), «нет» sentences always put the object in the genitive.\n\nEndings: masculine adds **-а/-я** (сыр → сы́ра), neuter changes **-о/-е → -а/-я** (молоко́ → молока́), feminine changes **-а/-я → -ы/-и** (вода́ → воды́).",
    "examples": [
      { "ru": "У меня́ нет вре́мени.", "en": "I don't have time.", "note": "время → времени (irregular-ish neuter)" },
      { "ru": "У меня́ нет молока́.", "en": "I don't have milk.", "note": "молоко → молока" },
      { "ru": "У тебя́ нет маши́ны?", "en": "You don't have a car?", "note": "машина → машины" },
      { "ru": "У нас нет сы́ра, но есть хлеб.", "en": "We don't have cheese, but we have bread.", "note": "у нас — same pattern, мы → нас" }
    ]
  },

  "vocab": [
