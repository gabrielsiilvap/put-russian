      "title": "In the kitchen",
      "lines": [
        { "speaker": "A", "ru": "У нас есть хлеб и масло. А сыр?", "en": "We have bread and butter. And cheese?" },
        { "speaker": "B", "ru": "Сыра нет. И сахара тоже нет.", "en": "No cheese. And no sugar either." },
