      { "ru": "В понеде́льник я рабо́таю.", "en": "On Monday I work." },
      { "ru": "Во вто́рник он отдыха́ет.", "en": "On Tuesday he rests." },
      { "ru": "В сре́ду мы гуля́ем.", "en": "On Wednesday we walk.", "note": "среда → среду, accusative" },
      { "ru": "Ско́лько вре́мени? — Сейча́с пять часо́в.", "en": "What time is it? — It's five o'clock." }
    ]
  },

